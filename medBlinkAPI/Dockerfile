# ----------------------------
# STAGE 1 - BUILD
# ----------------------------
FROM maven:3.9.6-eclipse-temurin-17 AS build

WORKDIR /app
COPY pom.xml .
COPY src ./src

RUN mvn clean package -DskipTests

# ----------------------------
# STAGE 2 - RUN
# ----------------------------
FROM eclipse-temurin:17-jdk

WORKDIR /app

COPY --from=build /app/target/*.jar Medblink.jar

EXPOSE 30082

ENTRYPOINT ["java","-jar","Medblink.jar"]